# ============================================================
# EVA-Mind - Environment Variables
# ============================================================
# Copy to .env and fill in your values
# For Cloud Run: set via gcloud run services update --set-env-vars
# ============================================================

# Server
PORT=8091
ENVIRONMENT=production
METRICS_PORT=9090

# PostgreSQL (REQUIRED)
DB_HOST=104.248.219.200
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_NAME=eva_db
DB_SSLMODE=disable

# Neo4j (Optional - graceful degradation)
NEO4J_URI=neo4j://104.248.219.200:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME

# Qdrant (Optional - graceful degradation)
QDRANT_HOST=104.248.219.200
QDRANT_PORT=6334

# Redis (Optional - graceful degradation)
REDIS_HOST=104.248.219.200
REDIS_PORT=6379
REDIS_PASSWORD=

# Google AI (REQUIRED for core features)
GOOGLE_API_KEY=CHANGE_ME
MODEL_ID=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash
VISION_MODEL_ID=gemini-2.0-flash-exp

# Authentication
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHARS

# Firebase (Optional)
FIREBASE_CREDENTIALS_PATH=

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=
GOOGLE_MAPS_API_KEY=

# Twilio (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ENABLE_SMS_FALLBACK=false
ENABLE_CALL_FALLBACK=false

# SMTP (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=web2ajax@gmail.com
SMTP_FROM_NAME=EVA - Assistente Virtual
ENABLE_EMAIL_FALLBACK=true

# App
APP_URL=https://eva-ia.org
